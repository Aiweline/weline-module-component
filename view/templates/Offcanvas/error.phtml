<!DOCTYPE html>
<html>
<head>
    <title>@lang{倒计时关闭页面...}</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <?php
    // 检查是否是后端请求
    $isBackend = $this->request->isBackend();
    $isDarkMode = false;
    
    if ($isBackend) {
        // 获取主题配置
        $themeConfig = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Backend\Block\ThemeConfig::class);
        $themeMode = $themeConfig->getThemeModel() ?? '';
        $isDarkMode = ($themeMode === 'dark');
        
        // 加载 Bootstrap CSS
        $bootstrapCss = $this->fetchTagSourceFile('statics', 'Weline_Admin::assets/css/bootstrap' . ($themeMode ? '-' . $themeMode : '') . '.min.css');
        if ($bootstrapCss) {
            echo '<link href="' . htmlspecialchars($bootstrapCss) . '" rel="stylesheet" type="text/css"/>';
        }
        
        // 加载图标字体
        $iconsCss = $this->fetchTagSourceFile('statics', 'Weline_Admin::assets/css/icons.min.css');
        if ($iconsCss) {
            echo '<link href="' . htmlspecialchars($iconsCss) . '" rel="stylesheet" type="text/css"/>';
        }
        
        // 加载 App CSS
        $appCss = $this->fetchTagSourceFile('statics', 'Weline_Admin::assets/css/app' . ($themeMode ? '-' . $themeMode : '') . '.min.css');
        if ($appCss) {
            echo '<link href="' . htmlspecialchars($appCss) . '" rel="stylesheet" type="text/css"/>';
        }
    } else {
        // 使用前端主题的CSS
        $frontendCss = $this->getStaticUrl('Weline_Frontend::assets/css/bootstrap.min.css') ?? '';
        if ($frontendCss) {
            echo '<link href="' . htmlspecialchars($frontendCss) . '" id="bootstrap-style" rel="stylesheet" type="text/css"/>';
        }
    }
    
    // 暗色模式下的颜色定义
    $bgColor = $isDarkMode ? '#212529' : '#f8f9fa';
    $cardBg = $isDarkMode ? '#2b2f38' : '#fff';
    $textColor = $isDarkMode ? '#e9ecef' : '#212529';
    $textMuted = $isDarkMode ? '#adb5bd' : '#6c757d';
    $borderColor = $isDarkMode ? '#343a40' : '#dee2e6';
    ?>
    <style>
        * {
            box-sizing: border-box;
        }
        :root {
            --offcanvas-bg: <?= $bgColor ?>;
            --offcanvas-card-bg: <?= $cardBg ?>;
            --offcanvas-text: <?= $textColor ?>;
            --offcanvas-text-muted: <?= $textMuted ?>;
            --offcanvas-border: <?= $borderColor ?>;
        }
        body {
            background-color: var(--offcanvas-bg);
            padding: 20px;
            margin: 0;
            font-family: var(--bs-font-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif);
            color: var(--offcanvas-text);
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        .offcanvas-result-card {
            max-width: 500px;
            margin: 0 auto;
            background: var(--offcanvas-card-bg);
            border: 1px solid var(--offcanvas-border);
            border-radius: 0.375rem;
            box-shadow: <?= $isDarkMode ? '0 0.125rem 0.25rem rgba(0, 0, 0, 0.3)' : '0 0.125rem 0.25rem rgba(0, 0, 0, 0.075)' ?>;
            overflow: hidden;
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }
        .card-header-danger {
            background: linear-gradient(135deg, rgba(255, 61, 96, 0.15) 0%, rgba(255, 61, 96, 0.25) 100%);
            border-bottom: 1px solid rgba(255, 61, 96, 0.2);
            padding: 1rem 1.25rem;
        }
        .card-header-danger h5 {
            color: #ff3d60 !important;
            font-size: 1rem;
            font-weight: 600;
            margin: 0;
            display: flex;
            align-items: center;
        }
        .card-header-danger .btn-close {
            background: transparent url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='%23ff3d60'%3e%3cpath d='M.293.293a1 1 0 011.414 0L8 6.586 14.293.293a1 1 0 111.414 1.414L9.414 8l6.293 6.293a1 1 0 01-1.414 1.414L8 9.414l-6.293 6.293a1 1 0 01-1.414-1.414L6.586 8 .293 1.707a1 1 0 010-1.414z'/%3e%3c/svg%3e") center/1em auto no-repeat;
            opacity: 0.8;
        }
        .card-header-danger .btn-close:hover {
            opacity: 1;
        }
        .card-body {
            padding: 2rem 1.5rem;
            text-align: center;
        }
        .error-icon {
            font-size: 4rem;
            color: #ff3d60;
            margin-bottom: 1.5rem;
            display: block;
            line-height: 1;
        }
        .error-title {
            color: #ff3d60 !important;
            font-size: 1.125rem;
            font-weight: 600;
            margin-bottom: 0.75rem;
        }
        .error-content {
            color: var(--offcanvas-text-muted);
            margin-bottom: 0.5rem;
        }
        .countdown-text {
            color: var(--offcanvas-text-muted);
            font-size: 0.875rem;
            margin-top: 1rem;
        }
        .d-flex {
            display: flex;
        }
        .align-items-center {
            align-items: center;
        }
        .justify-content-between {
            justify-content: space-between;
        }
        .mb-0 {
            margin-bottom: 0;
        }
        .mb-3 {
            margin-bottom: 1rem;
        }
        .mb-4 {
            margin-bottom: 1.5rem;
        }
        .me-2 {
            margin-right: 0.5rem;
        }
        .btn-close {
            padding: 0.5rem 0.5rem;
            margin: -0.5rem -0.5rem -0.5rem auto;
            background-color: transparent;
            border: 0;
            border-radius: 0.375rem;
            opacity: 0.5;
            cursor: pointer;
            width: 1em;
            height: 1em;
        }
        .btn-close:hover {
            opacity: 0.75;
        }
    </style>
</head>
<body data-offcanvas-result="error">
<div class="offcanvas-result-card">
    <div class="card-header-danger">
        <div class="d-flex align-items-center justify-content-between">
            <h5>
                <i class="mdi mdi-alert-circle me-2"></i>
                <lang>警告提示！</lang>
            </h5>
            <button type="button" class="btn-close" aria-label="Close"></button>
        </div>
    </div>
    <div class="card-body">
        <i class="mdi mdi-alert-outline error-icon"></i>
        <h4 class="error-title">{{msg}}</h4>
        <?php if (!empty($this->getData('content'))): ?>
            <p class="error-content">{{content}}</p>
        <?php endif; ?>
        <p class="countdown-text mb-0" id="countdown"></p>
    </div>
</div>
<script>
    // 从父窗口获取主题模式并应用（备用方案，确保主题同步）
    (function() {
        try {
            var parentBody = window.parent.document.body;
            var parentThemeMode = parentBody.getAttribute('data-theme-mode') || 
                                 parentBody.getAttribute('data-bs-theme') || 
                                 (parentBody.classList.contains('dark') ? 'dark' : 'light');
            
            // 如果父窗口是暗色模式，应用暗色样式
            if (parentThemeMode === 'dark') {
                document.documentElement.style.setProperty('--offcanvas-bg', '#212529');
                document.documentElement.style.setProperty('--offcanvas-card-bg', '#2b2f38');
                document.documentElement.style.setProperty('--offcanvas-text', '#e9ecef');
                document.documentElement.style.setProperty('--offcanvas-text-muted', '#adb5bd');
                document.documentElement.style.setProperty('--offcanvas-border', '#343a40');
                document.body.style.backgroundColor = '#212529';
                document.body.style.color = '#e9ecef';
                var card = document.querySelector('.offcanvas-result-card');
                if (card) {
                    card.style.backgroundColor = '#2b2f38';
                    card.style.borderColor = '#343a40';
                }
            } else {
                // 亮色模式
                document.documentElement.style.setProperty('--offcanvas-bg', '#f8f9fa');
                document.documentElement.style.setProperty('--offcanvas-card-bg', '#fff');
                document.documentElement.style.setProperty('--offcanvas-text', '#212529');
                document.documentElement.style.setProperty('--offcanvas-text-muted', '#6c757d');
                document.documentElement.style.setProperty('--offcanvas-border', '#dee2e6');
            }
        } catch (e) {
            // 跨域或其他错误时忽略，使用PHP设置的默认值
            console.log('Cannot access parent window theme:', e);
        }
    })();
    
    // 设置倒计时时间（单位：毫秒）
    var countdownTime = parseInt('{{time}}000');

    // 获取倒计时元素
    var countdownElement = document.getElementById('countdown');

    // 倒计时函数
    function countdown() {
        // 减少剩余时间
        countdownTime -= 1000;
        // 更新倒计时元素的文本内容
        countdownElement.textContent = '@lang{页面将在} ' + (countdownTime / 1000) + ' @lang{秒后关闭}';

        // 如果剩余时间大于 0，则继续倒计时
        if (countdownTime > 0) {
            setTimeout(countdown, 1000);
        } else {
            // 关闭页面
            var $ = parent.$;
            let parentDocument = parent.$(window.parent.document)
            let closeOffcanvasButton = parentDocument.find('.offcanvas-header button')
            closeOffcanvasButton.click()
            let reload = parseInt('{{reload}}')
            if(reload){
                parent.location.reload();
            }
        }
    }

    // 启动倒计时
    countdown();
</script>
</body>
</html>
