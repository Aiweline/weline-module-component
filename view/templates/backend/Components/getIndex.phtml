<script>
document.addEventListener('DOMContentLoaded', function() {
    // 组件详情查看功能
    const detailButtons = document.querySelectorAll('.btn-view-detail');
    
    detailButtons.forEach(button => {
        button.addEventListener('click', function() {
            const componentClass = this.getAttribute('data-component-class');
            if (!componentClass) {
                return;
            }
            
            // 使用 OffCanvas 或 Modal 显示详情
            // 这里可以使用框架的 OffCanvas 组件
            fetch('*/backend/components/detail?class=' + encodeURIComponent(componentClass), {
                method: 'GET',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // 显示组件详情
                    showComponentDetail(data.component);
                } else {
                    (window.parent&&window.parent.BackendToast?window.parent.BackendToast.error(data.message||'<?= addslashes(__('加载详情失败')) ?>'):console.error(data.message||'<?= addslashes(__('加载详情失败')) ?>'));
                }
            })
            .catch(error => {
                console.error('Error:', error);
                (window.parent&&window.parent.BackendToast?window.parent.BackendToast.error('<?= addslashes(__('加载详情失败')) ?>'):console.error('<?= addslashes(__('加载详情失败')) ?>'));
            });
        });
    });
    
    function showComponentDetail(component) {
        // 创建详情弹窗
        const modal = document.createElement('div');
        modal.className = 'component-detail-modal';
        modal.style.cssText = `
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        `;
        
        const content = document.createElement('div');
        content.style.cssText = `
            background-color: var(--card-bg, #ffffff);
            border-radius: 8px;
            padding: 2rem;
            max-width: 800px;
            max-height: 80vh;
            overflow-y: auto;
            box-shadow: var(--shadow-lg, 0 4px 12px rgba(11, 177, 151, 0.15));
            color: var(--text-color, #212529);
        `;
        
        const docHtml = component.doc || '<p><?= __('暂无文档') ?></p>';
        
        content.innerHTML = `
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color, #eff2f7); padding-bottom: 1rem;">
                <h2 style="margin: 0; color: var(--text-color, #212529);">${component.class || ''}</h2>
                <button class="close-modal" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text-secondary, #74788d);">&times;</button>
            </div>
            <div style="margin-bottom: 1rem;">
                <strong><?= __('模块') ?>：</strong>
                <span class="badge" style="background-color: var(--info-color, #4aa3ff); color: white; padding: 0.25rem 0.5rem; border-radius: 4px;">${component.module || ''}</span>
            </div>
            <div style="margin-bottom: 1rem;">
                <strong><?= __('分类') ?>：</strong>
                <span class="badge" style="background-color: var(--success-color, #0ac074); color: white; padding: 0.25rem 0.5rem; border-radius: 4px;">${component.category || '<?= __('其他') ?>'}</span>
            </div>
            <div style="margin-bottom: 1rem;">
                <strong><?= __('完整类名') ?>：</strong>
                <code style="background-color: var(--bg-color, #f8f9fa); padding: 0.25rem 0.5rem; border-radius: 4px; color: var(--primary-color, #0bb197);">${component.full_class || ''}</code>
            </div>
            <div style="margin-top: 1.5rem;">
                <strong><?= __('使用文档') ?>：</strong>
                <div style="margin-top: 0.5rem; padding: 1rem; background-color: var(--bg-color, #f8f9fa); border-radius: 4px; border: 1px solid var(--border-color, #eff2f7);">
                    ${docHtml}
                </div>
            </div>
        `;
        
        modal.appendChild(content);
        document.body.appendChild(modal);
        
        // 关闭按钮事件
        const closeBtn = content.querySelector('.close-modal');
        closeBtn.addEventListener('click', () => {
            document.body.removeChild(modal);
        });
        
        // 点击背景关闭
        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                document.body.removeChild(modal);
            }
        });
    }
});
</script>

