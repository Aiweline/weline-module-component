<style id="wf-flash-component-styles">

/* Framework flash — MessageManager / .wf-system-messages */

.wf-system-messages:not(:has(.wflash)) {
    display: none;
}

.wf-system-messages {
    width: 100%;
}

.wf-system-messages .system.message {
    width: 100%;
}

.wf-system-messages .system.message .wflash {
    position: relative;
    margin-bottom: 1rem;
    border-radius: 0.75rem;
    border: 1px solid #cbd5e1;
    padding: 0.875rem 1rem;
    padding-inline-end: 2.75rem;
    font-size: 0.9375rem;
    line-height: 1.55;
    box-sizing: border-box;
    animation: wf-flash-in 0.35s ease-out;
}

@keyframes wf-flash-in {
    from {
        opacity: 0;
        transform: translateY(-4px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.wf-system-messages .system.message .wflash:not(.wflash--dismissible) {
    padding-inline-end: 1rem;
}

.wf-system-messages .system.message .wflash__title {
    font-weight: 700;
}

.wf-system-messages .system.message .wflash__body {
    font-weight: inherit;
}

.wf-system-messages .system.message .wflash__close {
    position: absolute;
    inset-inline-end: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    width: 2rem;
    height: 2rem;
    margin: 0;
    padding: 0;
    border: 0;
    border-radius: 0.375rem;
    background: transparent
        url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='%2364748b' d='M.293.293a1 1 0 011.414 0L8 6.586 14.293.293a1 1 0 111.414 1.414L9.414 8l6.293 6.293a1 1 0 01-1.414 1.414L8 9.414l-6.293 6.293a1 1 0 01-1.414-1.414L6.586 8 .293 1.707a1 1 0 010-1.414z'/%3e%3c/svg%3e")
        center / 0.85rem auto no-repeat;
    cursor: pointer;
    opacity: 0.72;
    flex-shrink: 0;
}

.wf-system-messages .system.message .wflash__close:hover {
    opacity: 1;
    background-color: rgba(0, 0, 0, 0.07);
}

.wf-system-messages .system.message .wflash__close:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.65);
    outline-offset: 2px;
}

.wf-system-messages .system.message .wflash--success {
    background: linear-gradient(180deg, #ecfdf5 0%, #d1fae5 100%);
    border: 2px solid #34d399;
    color: #065f46;
